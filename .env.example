# AgentPulse — Environment Variables
# Copy this file to .env and fill in your Azure OpenAI credentials.
# NEVER commit .env to git.

# Azure OpenAI — used for agent responses AND DeepEval quality scoring
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=<chat-deployment-name>        # e.g. gpt-4o or gpt-5.2-chat-2
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure OpenAI Embeddings — optional, for replacing Ollama FAISS embeddings
# If not set, the framework falls back to Ollama nomic-embed-text
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_EMBEDDING_API_VERSION=2024-12-01-preview
